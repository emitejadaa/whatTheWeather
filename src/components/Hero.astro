<section id="inicio" class="hero">
  <div class="container hero-content">
    <div class="hero-text">
      <p class="eyebrow">Weather dashboard</p>
      <h1>Consultá el clima de cualquier ciudad</h1>
      <p class="hero-description">
        Buscá una ubicación y obtené el clima actual con una interfaz moderna,
        simple y preparada para seguir creciendo con más visualizaciones.
      </p>

      <div class="search-form">
        <label for="city-input" class="sr-only">Ingresar ciudad</label>
        <input
          id="city-input"
          type="text"
          placeholder="Ej: Buenos Aires"
          autocomplete="off"
        />
        <button id="search-button" type="button" class="button primary">
          Buscar
        </button>
      </div>

      <p id="form-status" class="form-status" aria-live="polite"></p>
    </div>

    <div class="hero-card">
      <div class="weather-preview">
        <span id="hero-icon" class="weather-icon">☀️</span>
        <div>
          <p class="preview-label">Clima actual</p>
          <h2 id="hero-temp">--°C</h2>
          <p id="hero-city" class="preview-city">Esperando búsqueda...</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function getWeatherEmoji(text) {
    const value = text.toLowerCase();

    if (value.includes("sun") || value.includes("soleado") || value.includes("despejado")) {
      return "☀️";
    }
    if (value.includes("cloud") || value.includes("nublado")) {
      return "☁️";
    }
    if (value.includes("rain") || value.includes("lluv")) {
      return "🌧️";
    }
    if (value.includes("storm") || value.includes("torment")) {
      return "⛈️";
    }
    if (value.includes("snow") || value.includes("nieve")) {
      return "❄️";
    }
    if (value.includes("mist") || value.includes("fog") || value.includes("niebla")) {
      return "🌫️";
    }

    return "🌤️";
  }

  function renderForecast(days) {
    const forecastContainer = document.querySelector("#forecast-list");
    if (!forecastContainer) return;

    forecastContainer.innerHTML = "";

    days.forEach((day) => {
      const item = document.createElement("article");
      item.className = "card forecast-item";

      const date = new Date(day.date + "T12:00:00");
      const formattedDate = date.toLocaleDateString("es-AR", {
        weekday: "short",
        day: "numeric",
        month: "short",
      });

      item.innerHTML = `
        <p class="forecast-day">${formattedDate}</p>
        <p class="forecast-emoji">${getWeatherEmoji(day.day.condition.text)}</p>
        <p class="forecast-condition">${day.day.condition.text}</p>
        <p class="forecast-range">${Math.round(day.day.maxtemp_c)}° / ${Math.round(day.day.mintemp_c)}°</p>
      `;

      forecastContainer.appendChild(item);
    });
  }

  function renderWeather(data) {
    const current = data.current;
    const location = data.location;
    const forecastDays = data.forecast?.forecastday ?? [];

    const heroTemp = document.querySelector("#hero-temp");
    const heroCity = document.querySelector("#hero-city");
    const heroIcon = document.querySelector("#hero-icon");

    const tempCard = document.querySelector("#temp-value");
    const conditionCard = document.querySelector("#condition-value");
    const feelsLikeCard = document.querySelector("#feelslike-value");
    const humidityCard = document.querySelector("#humidity-value");
    const windCard = document.querySelector("#wind-value");
    const locationCard = document.querySelector("#location-value");

    const conditionText = current.condition.text;
    const emoji = getWeatherEmoji(conditionText);

    if (heroTemp) heroTemp.textContent = `${Math.round(current.temp_c)}°C`;
    if (heroCity) heroCity.textContent = `${location.name}, ${location.country}`;
    if (heroIcon) heroIcon.textContent = emoji;

    if (tempCard) tempCard.textContent = `${Math.round(current.temp_c)}°C`;
    if (conditionCard) conditionCard.textContent = conditionText;
    if (feelsLikeCard) feelsLikeCard.textContent = `${Math.round(current.feelslike_c)}°C`;
    if (humidityCard) humidityCard.textContent = `${current.humidity}%`;
    if (windCard) windCard.textContent = `${current.wind_kph} km/h`;
    if (locationCard) locationCard.textContent = `${location.name}, ${location.region}`;

    renderForecast(forecastDays);
  }

  async function fetchWeather(city) {
    const status = document.querySelector("#form-status");
    const button = document.querySelector("#search-button");

    if (status) status.textContent = "Buscando clima...";
    if (button) button.setAttribute("disabled", "true");

    try {
      console.log("Enviando city al backend:", city);

      const response = await fetch("/api/weather", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ city }),
      });

      const text = await response.text();
      console.log("Respuesta cruda:", text);

      let data;
      try {
        data = JSON.parse(text);
      } catch {
        throw new Error("La respuesta del servidor no es JSON válido");
      }

      if (!response.ok) {
        throw new Error(data.error || "No se pudo obtener la información");
      }

      renderWeather(data);
      if (status) status.textContent = `Mostrando resultados para ${data.location.name}.`;
    } catch (error) {
      console.error(error);
      if (status) {
        status.textContent =
          error instanceof Error
            ? error.message
            : "Ocurrió un error al buscar la ciudad.";
      }
    } finally {
      if (button) button.removeAttribute("disabled");
    }
  }

  function setupWeatherSearch() {
    const input = document.querySelector("#city-input");
    const button = document.querySelector("#search-button");

    if (!(input instanceof HTMLInputElement) || !(button instanceof HTMLButtonElement)) {
      console.log("No se encontraron input o botón del clima");
      return;
    }

    button.addEventListener("click", async () => {
      const city = input.value.trim();
      console.log("City desde input:", city);

      if (!city) {
        const status = document.querySelector("#form-status");
        if (status) status.textContent = "Ingresá una ciudad antes de buscar.";
        return;
      }

      await fetchWeather(city);
    });

    input.addEventListener("keydown", async (event) => {
      if (event.key === "Enter") {
        event.preventDefault();

        const city = input.value.trim();
        console.log("City desde Enter:", city);

        if (!city) {
          const status = document.querySelector("#form-status");
          if (status) status.textContent = "Ingresá una ciudad antes de buscar.";
          return;
        }

        await fetchWeather(city);
      }
    });

    fetchWeather("Buenos Aires");
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupWeatherSearch);
  } else {
    setupWeatherSearch();
  }
</script>