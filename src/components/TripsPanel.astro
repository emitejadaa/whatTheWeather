---
// Panel for managing saved trips.
---

<div id="trips-panel" class="trips-panel">
  <div class="trips-toolbar">
    <div>
      <p class="trips-kicker">Viajes</p>
      <h3>Mis viajes guardados</h3>
    </div>
    <span id="trips-count" class="trips-count">0</span>
  </div>

  <div class="trips-tabs" role="tablist" aria-label="Secciones de viajes">
    <button
      id="trips-list-tab"
      class="trips-tab is-active"
      type="button"
      data-trips-view="list"
      aria-selected="true"
    >
      Lista
    </button>
    <button
      id="trips-new-tab"
      class="trips-tab"
      type="button"
      data-trips-view="new"
      aria-selected="false"
    >
      Nuevo
    </button>
  </div>

  <section id="trips-list-view" class="trips-view is-active" aria-labelledby="trips-list-tab">
    <div id="trips-list" class="trips-list">
      <div class="empty-state">
        <p>Todavia no guardaste viajes.</p>
      </div>
    </div>
  </section>

  <section id="trips-new-view" class="trips-view" aria-labelledby="trips-new-tab">
    <form id="trips-form" class="trips-form">
      <div class="form-group">
        <label for="trip-name">Nombre del viaje</label>
        <input
          id="trip-name"
          type="text"
          placeholder="Ej: Vacaciones en Bariloche"
          maxlength="100"
        />
      </div>

      <div class="form-group">
        <label for="trip-destination">Destino</label>
        <input
          id="trip-destination"
          type="text"
          placeholder="Ej: Bariloche, Argentina"
          maxlength="150"
        />
      </div>

      <div class="trips-date-grid">
        <div class="form-group">
          <label for="trip-start-date">Inicio</label>
          <input id="trip-start-date" type="date" />
        </div>

        <div class="form-group">
          <label for="trip-end-date">Fin</label>
          <input id="trip-end-date" type="date" />
        </div>
      </div>

      <button type="submit" class="button primary trips-submit">Guardar viaje</button>
    </form>
  </section>

  <p id="trips-form-status" class="trips-status" aria-live="polite"></p>

  <div
    id="trip-detail-modal"
    class="trip-detail-modal hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="trip-detail-title"
    aria-hidden="true"
  >
    <div class="trip-detail-dialog">
      <div class="trip-detail-header">
        <div>
          <p id="trip-detail-destination" class="trips-kicker"></p>
          <h3 id="trip-detail-title">Detalle del viaje</h3>
        </div>
        <button
          id="trip-detail-close"
          class="trip-detail-close"
          type="button"
          aria-label="Cerrar detalle"
        >
          x
        </button>
      </div>

      <div id="trip-detail-body" class="trip-detail-body"></div>
    </div>
  </div>
</div>

<style>
  .trips-panel {
    display: grid;
    gap: 1rem;
  }

  .trips-toolbar,
  .trip-detail-header,
  .trip-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .trips-toolbar h3,
  .trip-detail-header h3 {
    margin: 0.15rem 0 0;
    color: var(--text);
    font-size: 1.2rem;
    line-height: 1.25;
  }

  .trips-kicker {
    margin: 0;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .trips-count {
    min-width: 42px;
    min-height: 42px;
    display: inline-grid;
    place-items: center;
    border-radius: 8px;
    background: var(--accent-soft);
    color: var(--accent);
    font-weight: 800;
  }

  .trips-tabs {
    display: inline-flex;
    width: fit-content;
    padding: 0.35rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    gap: 0.25rem;
  }

  .trips-tab {
    min-height: 36px;
    padding: 0 0.9rem;
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    color: var(--text-secondary);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
  }

  .trips-tab:hover {
    color: var(--text);
    background: var(--surface-soft);
  }

  .trips-tab.is-active {
    color: #ffffff;
    background: var(--accent);
    border-color: var(--accent);
  }

  .trips-view {
    display: none;
  }

  .trips-view.is-active {
    display: block;
  }

  .trips-list {
    display: grid;
    gap: 0.75rem;
  }

  .trip-card {
    display: grid;
    gap: 0.9rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface-soft);
  }

  .trip-card h4 {
    margin: 0;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.3;
  }

  .trip-destination,
  .trip-dates,
  .trip-meta {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .trip-destination {
    color: var(--accent);
    font-weight: 700;
  }

  .trip-days {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 0.6rem;
    border-radius: 6px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .trip-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .trip-action {
    min-height: 36px;
    padding: 0 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font: inherit;
    font-size: 0.86rem;
    font-weight: 700;
    cursor: pointer;
  }

  .trip-action:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .trip-action.danger {
    color: var(--danger);
  }

  .trip-action.danger:hover {
    border-color: var(--danger);
    background: rgba(239, 68, 68, 0.08);
  }

  .trips-form {
    display: grid;
    gap: 1rem;
  }

  .trips-date-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .form-group {
    display: grid;
    gap: 0.45rem;
  }

  .form-group label {
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .form-group input {
    width: 100%;
    min-height: 42px;
    padding: 0 0.85rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .trips-submit {
    width: 100%;
  }

  .trips-status {
    min-height: 22px;
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .trips-status.success {
    color: var(--success);
  }

  .trips-status.error {
    color: var(--danger);
  }

  .empty-state {
    padding: 1rem;
    border: 1px dashed var(--border);
    border-radius: 8px;
    color: var(--muted);
    background: var(--surface-soft);
  }

  .empty-state p {
    margin: 0;
    line-height: 1.6;
  }

  .trip-detail-modal {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgba(15, 23, 42, 0.64);
    backdrop-filter: blur(8px);
  }

  .trip-detail-dialog {
    width: min(100%, 720px);
    max-height: min(86vh, 760px);
    overflow: auto;
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    box-shadow: var(--shadow-lg);
  }

  .trip-detail-close {
    width: 40px;
    height: 40px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface-soft);
    color: var(--text);
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .trip-detail-body {
    display: grid;
    gap: 1rem;
  }

  .trip-detail-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .trip-detail-stat,
  .weather-day {
    padding: 0.85rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface-soft);
  }

  .trip-detail-stat span,
  .weather-date {
    display: block;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .trip-detail-stat strong {
    display: block;
    margin-top: 0.3rem;
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .weather-panel {
    display: grid;
    gap: 0.75rem;
  }

  .weather-panel h4 {
    margin: 0;
    color: var(--text);
  }

  .weather-days {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.75rem;
  }

  .weather-icon {
    width: 36px;
    height: 36px;
    margin: 0.5rem 0;
  }

  .weather-temp {
    color: var(--text);
    font-weight: 800;
  }

  .weather-condition,
  .weather-unavailable,
  .weather-loading {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 700px) {
    .trips-toolbar,
    .trip-card-header,
    .trip-detail-header {
      flex-direction: column;
      align-items: stretch;
    }

    .trips-tabs,
    .trips-tab {
      width: 100%;
    }

    .trips-date-grid,
    .trip-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  interface Trip {
    id: string;
    trip_name: string;
    destination_name: string;
    destination_query: string;
    start_date: string;
    end_date: string;
    created_at: string;
  }

  interface WeatherDay {
    date: string;
    maxTempC: number;
    minTempC: number;
    avgTempC: number;
    condition: string;
    conditionIcon: string;
    chanceOfRain: number;
    humidity: number;
  }

  interface WeatherData {
    destination: string;
    startDate: string;
    endDate: string;
    availableForecast: boolean;
    reason?: string;
    forecastDays: WeatherDay[];
  }

  let isTripsUserAuthenticated = false;
  let tripsState: Trip[] = [];
  const weatherCache = new Map<string, WeatherData | null>();

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function setStatus(message: string, type?: "success" | "error") {
    const element = document.getElementById("trips-form-status");
    if (!element) return;

    element.textContent = message;
    element.classList.toggle("success", type === "success");
    element.classList.toggle("error", type === "error");
  }

  function setTripsView(view: "list" | "new") {
    document.querySelectorAll("[data-trips-view]").forEach((button) => {
      const isActive = button.getAttribute("data-trips-view") === view;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-selected", String(isActive));
    });

    document.querySelector("#trips-list-view")?.classList.toggle("is-active", view === "list");
    document.querySelector("#trips-new-view")?.classList.toggle("is-active", view === "new");
  }

  function calculateDays(startDate: string, endDate: string) {
    const start = new Date(`${startDate}T00:00:00`);
    const end = new Date(`${endDate}T00:00:00`);
    return Math.floor((end.getTime() - start.getTime()) / 86400000) + 1;
  }

  function formatDate(dateString: string) {
    const date = new Date(`${dateString}T00:00:00`);
    return date.toLocaleDateString("es-AR", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    });
  }

  function renderTripsLoggedOut() {
    tripsState = [];
    updateTripsCount();

    const tripsList = document.getElementById("trips-list");
    if (!tripsList) return;

    tripsList.innerHTML = `
      <div class="empty-state">
        <p>Inicia sesion para guardar viajes y abrir el detalle de cada destino.</p>
      </div>
    `;
  }

  function updateTripsCount() {
    const count = document.getElementById("trips-count");
    if (count) {
      count.textContent = String(tripsState.length);
    }
  }

  async function fetchTripWeather(trip: Trip): Promise<WeatherData | null> {
    if (weatherCache.has(trip.id)) {
      return weatherCache.get(trip.id) ?? null;
    }

    try {
      const response = await fetch("/api/trips/weather", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          destination: trip.destination_name,
          startDate: trip.start_date,
          endDate: trip.end_date,
        }),
      });

      if (!response.ok) {
        weatherCache.set(trip.id, null);
        return null;
      }

      const data = await response.json();
      weatherCache.set(trip.id, data);
      return data;
    } catch (error) {
      console.error("Error fetching trip weather:", error);
      weatherCache.set(trip.id, null);
      return null;
    }
  }

  function renderWeatherForTrip(weatherData: WeatherData | null) {
    if (!weatherData) {
      return `<p class="weather-unavailable">No se pudo cargar el pronostico.</p>`;
    }

    if (!weatherData.availableForecast) {
      return `<p class="weather-unavailable">${escapeHtml(weatherData.reason || "El pronostico todavia no esta disponible para estas fechas.")}</p>`;
    }

    if (weatherData.forecastDays.length === 0) {
      return `<p class="weather-unavailable">Sin informacion meteorologica disponible.</p>`;
    }

    const daysHtml = weatherData.forecastDays
      .map((day) => {
        const condition = escapeHtml(day.condition);
        const icon = escapeHtml(day.conditionIcon);

        return `
          <div class="weather-day">
            <span class="weather-date">${formatDate(day.date)}</span>
            <img src="${icon}" alt="${condition}" class="weather-icon" />
            <div class="weather-temp">${Math.round(day.avgTempC)} C</div>
            <div class="weather-condition">${condition}</div>
            <div class="weather-condition">Lluvia ${Number(day.chanceOfRain) || 0}%</div>
          </div>
        `;
      })
      .join("");

    return `<div class="weather-days">${daysHtml}</div>`;
  }

  function renderTripCard(trip: Trip) {
    const card = document.createElement("article");
    const days = calculateDays(trip.start_date, trip.end_date);

    card.className = "trip-card";
    card.id = `trip-${trip.id}`;
    card.innerHTML = `
      <div class="trip-card-header">
        <div>
          <h4>${escapeHtml(trip.trip_name)}</h4>
          <p class="trip-destination">${escapeHtml(trip.destination_name)}</p>
          <p class="trip-dates">${formatDate(trip.start_date)} - ${formatDate(trip.end_date)}</p>
        </div>
        <span class="trip-days">${days} ${days === 1 ? "dia" : "dias"}</span>
      </div>
      <p class="trip-meta">Guardado el ${formatDate(trip.created_at.slice(0, 10))}</p>
      <div class="trip-actions">
        <button class="trip-action" type="button" data-trip-detail="${trip.id}">Ver detalle</button>
        <button class="trip-action danger" type="button" data-trip-delete="${trip.id}">Eliminar</button>
      </div>
    `;

    card.querySelector("[data-trip-detail]")?.addEventListener("click", () => openTripDetail(trip.id));
    card.querySelector("[data-trip-delete]")?.addEventListener("click", () => deleteTrip(trip.id));

    return card;
  }

  function renderTripsList() {
    const tripsList = document.getElementById("trips-list");
    if (!tripsList) return;

    updateTripsCount();

    if (!isTripsUserAuthenticated) {
      renderTripsLoggedOut();
      return;
    }

    if (tripsState.length === 0) {
      tripsList.innerHTML = `
        <div class="empty-state">
          <p>Todavia no guardaste viajes. Crea uno desde la pestana Nuevo.</p>
        </div>
      `;
      return;
    }

    tripsList.innerHTML = "";
    tripsState.forEach((trip) => {
      tripsList.appendChild(renderTripCard(trip));
    });
  }

  async function loadTrips() {
    if (!isTripsUserAuthenticated) {
      renderTripsLoggedOut();
      return;
    }

    try {
      setStatus("Cargando viajes...");
      const response = await fetch("/api/trips");

      if (response.status === 401) {
        isTripsUserAuthenticated = false;
        renderTripsLoggedOut();
        setStatus("");
        return;
      }

      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.error || "No se pudieron cargar los viajes");
      }

      tripsState = data.trips || [];
      renderTripsList();
      setStatus("");
    } catch (error) {
      console.error("Error loading trips:", error);
      setStatus(error instanceof Error ? error.message : "No se pudieron cargar los viajes", "error");
    }
  }

  async function openTripDetail(tripId: string) {
    const trip = tripsState.find((item) => item.id === tripId);
    const modal = document.getElementById("trip-detail-modal");
    const title = document.getElementById("trip-detail-title");
    const destination = document.getElementById("trip-detail-destination");
    const body = document.getElementById("trip-detail-body");

    if (!trip || !modal || !title || !destination || !body) return;

    const days = calculateDays(trip.start_date, trip.end_date);

    title.textContent = trip.trip_name;
    destination.textContent = trip.destination_name;
    body.innerHTML = `
      <div class="trip-detail-grid">
        <div class="trip-detail-stat">
          <span>Inicio</span>
          <strong>${formatDate(trip.start_date)}</strong>
        </div>
        <div class="trip-detail-stat">
          <span>Fin</span>
          <strong>${formatDate(trip.end_date)}</strong>
        </div>
        <div class="trip-detail-stat">
          <span>Duracion</span>
          <strong>${days} ${days === 1 ? "dia" : "dias"}</strong>
        </div>
      </div>
      <section class="weather-panel">
        <h4>Pronostico del viaje</h4>
        <p class="weather-loading">Cargando pronostico...</p>
      </section>
    `;

    modal.classList.remove("hidden");
    modal.setAttribute("aria-hidden", "false");

    const weatherData = await fetchTripWeather(trip);
    const weatherPanel = body.querySelector(".weather-panel");
    if (weatherPanel) {
      weatherPanel.innerHTML = `
        <h4>Pronostico del viaje</h4>
        ${renderWeatherForTrip(weatherData)}
      `;
    }
  }

  function closeTripDetail() {
    const modal = document.getElementById("trip-detail-modal");
    if (!modal) return;

    modal.classList.add("hidden");
    modal.setAttribute("aria-hidden", "true");
  }

  async function deleteTrip(tripId: string) {
    if (!window.confirm("Eliminar este viaje?")) {
      return;
    }

    try {
      const response = await fetch(`/api/trips?id=${encodeURIComponent(tripId)}`, {
        method: "DELETE",
      });
      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.error || "No se pudo eliminar el viaje");
      }

      tripsState = tripsState.filter((trip) => trip.id !== tripId);
      weatherCache.delete(tripId);
      renderTripsList();
      closeTripDetail();
      setStatus("Viaje eliminado correctamente", "success");
    } catch (error) {
      console.error("Error deleting trip:", error);
      setStatus(error instanceof Error ? error.message : "No se pudo eliminar el viaje", "error");
    }
  }

  async function handleFormSubmit(event: Event) {
    event.preventDefault();

    if (!isTripsUserAuthenticated) {
      setStatus("Inicia sesion para guardar viajes", "error");
      return;
    }

    const nameInput = document.getElementById("trip-name") as HTMLInputElement | null;
    const destinationInput = document.getElementById("trip-destination") as HTMLInputElement | null;
    const startInput = document.getElementById("trip-start-date") as HTMLInputElement | null;
    const endInput = document.getElementById("trip-end-date") as HTMLInputElement | null;

    if (!nameInput || !destinationInput || !startInput || !endInput) return;

    const tripName = nameInput.value.trim();
    const destination = destinationInput.value.trim();
    const startDate = startInput.value;
    const endDate = endInput.value;

    if (!tripName || !destination || !startDate || !endDate) {
      setStatus("Completa todos los campos", "error");
      return;
    }

    if (new Date(`${startDate}T00:00:00`) > new Date(`${endDate}T00:00:00`)) {
      setStatus("La fecha de inicio no puede ser posterior a la fecha de fin", "error");
      return;
    }

    if (calculateDays(startDate, endDate) > 31) {
      setStatus("El viaje no puede exceder 30 dias", "error");
      return;
    }

    try {
      const response = await fetch("/api/trips", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          tripName,
          destination,
          startDate,
          endDate,
        }),
      });
      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.error || "No se pudo guardar el viaje");
      }

      nameInput.value = "";
      destinationInput.value = "";
      startInput.value = "";
      endInput.value = "";

      await loadTrips();
      setTripsView("list");
      setStatus("Viaje guardado correctamente", "success");
    } catch (error) {
      console.error("Error saving trip:", error);
      setStatus(error instanceof Error ? error.message : "No se pudo guardar el viaje", "error");
    }
  }

  async function initializeTripsPanel() {
    try {
      const response = await fetch("/api/auth/session");
      const data = await response.json();

      isTripsUserAuthenticated = Boolean(data.user);
      await loadTrips();
    } catch (error) {
      console.error("Error checking trip session:", error);
      renderTripsLoggedOut();
    }
  }

  document.querySelectorAll("[data-trips-view]").forEach((button) => {
    button.addEventListener("click", () => {
      const view = button.getAttribute("data-trips-view") === "new" ? "new" : "list";
      setTripsView(view);
    });
  });

  document.getElementById("trips-form")?.addEventListener("submit", handleFormSubmit);
  document.getElementById("trip-detail-close")?.addEventListener("click", closeTripDetail);
  document.getElementById("trip-detail-modal")?.addEventListener("click", (event) => {
    if (event.target === event.currentTarget) {
      closeTripDetail();
    }
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeTripDetail();
    }
  });

  window.addEventListener("auth:changed", async (event) => {
    isTripsUserAuthenticated = Boolean(event.detail?.user);
    weatherCache.clear();
    await loadTrips();
  });

  initializeTripsPanel();
</script>
