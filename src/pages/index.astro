---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import SectionTitle from "../components/SectionTitle.astro";
import "../styles/global.css";
---

<MainLayout title="SkyCast | App del clima">
  <Header />
  <main>
    <Hero />

    <section id="actual" class="section">
      <div class="container">
        <SectionTitle
          eyebrow="Sección 1"
          title="Clima actual"
          text="Resultados principales de la ciudad buscada, con foco en una lectura rápida."
        />

        <div class="grid cards-3">
          <article class="card">
            <h3>Temperatura</h3>
            <p id="temp-value" class="big-number">--°C</p>
            <p>Temperatura actual registrada.</p>
          </article>

          <article class="card">
            <h3>Estado</h3>
            <p id="condition-value" class="big-number big-label">--</p>
            <p>Condición meteorológica actual.</p>
          </article>

          <article class="card">
            <h3>Sensación térmica</h3>
            <p id="feelslike-value" class="big-number">--°C</p>
            <p>Temperatura percibida.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="detalles" class="section alt-section">
      <div class="container">
        <SectionTitle
          eyebrow="Sección 2"
          title="Detalles adicionales"
          text="Datos complementarios que después vamos a volver más visuales con barras e indicadores."
        />

        <div class="grid cards-3">
          <article class="card">
            <h3>Humedad</h3>
            <p id="humidity-value" class="big-number">--%</p>
            <p>Nivel de humedad relativa.</p>
          </article>

          <article class="card">
            <h3>Viento</h3>
            <p id="wind-value" class="big-number">-- km/h</p>
            <p>Velocidad actual del viento.</p>
          </article>

          <article class="card">
            <h3>Ubicación</h3>
            <p id="location-value" class="big-number big-label">--</p>
            <p>Ciudad y región consultadas.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="pronostico" class="section">
      <div class="container">
        <SectionTitle
          eyebrow="Sección 3"
          title="Pronóstico corto"
          text="Vista rápida de los próximos días. Más adelante lo vamos a convertir en una parte todavía más visual."
        />

        <div id="forecast-list" class="forecast-grid">
          <article class="card forecast-item">
            <p class="forecast-day">--</p>
            <p class="forecast-emoji">🌤️</p>
            <p class="forecast-condition">Esperando datos...</p>
            <p class="forecast-range">--° / --°</p>
          </article>
        </div>
      </div>
    </section>
  </main>
</MainLayout>