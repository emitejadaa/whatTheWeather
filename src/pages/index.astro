---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import SectionTitle from "../components/SectionTitle.astro";
import MetricCard from "../components/MetricCard.astro";
import DetailMeter from "../components/DetailMeter.astro";
import "../styles/global.css";
---

<MainLayout title="SkyCast | App del clima">
  <Header />
  <main>
    <Hero />

    <section id="actual" class="section">
      <div class="container">
        <SectionTitle
          eyebrow="Sección 1"
          title="Clima actual"
          text="Resultados principales de la ciudad buscada, con foco en una lectura rápida."
        />

        <div class="grid cards-3">
          <MetricCard
            title="Temperatura"
            valueId="temp-value"
            value="--°C"
            description="Temperatura actual registrada."
          />

          <MetricCard
            title="Estado"
            valueId="condition-value"
            value="--"
            description="Condición meteorológica actual."
            largeLabel={true}
          />

          <MetricCard
            title="Sensación térmica"
            valueId="feelslike-value"
            value="--°C"
            description="Temperatura percibida."
          />
        </div>
      </div>
    </section>

    <section id="detalles" class="section alt-section">
      <div class="container">
        <SectionTitle
          eyebrow="Sección 2"
          title="Detalles visuales"
          text="Indicadores complementarios mostrados de una forma más gráfica para que la app se sienta más tipo dashboard."
        />

        <div class="grid cards-3">
          <DetailMeter
            title="Humedad"
            valueId="humidity-value"
            fillId="humidity-fill"
            value="--%"
            description="Nivel de humedad relativa actual."
          />

          <DetailMeter
            title="Sensación térmica"
            valueId="feelslike-meter-value"
            fillId="feelslike-fill"
            value="--°C"
            description="Representación visual de la temperatura percibida."
          />

          <MetricCard
            title="Viento"
            valueId="wind-value"
            value="-- km/h"
            description="Velocidad actual del viento."
          />
        </div>

        <div class="grid cards-2 extra-details-grid">
          <MetricCard
            title="Ubicación"
            valueId="location-value"
            value="--"
            description="Ciudad y región consultadas."
            largeLabel={true}
          />

          <article class="card summary-card">
            <h3>Resumen rápido</h3>
            <div class="summary-inline">
              <span id="summary-icon" class="summary-icon">🌤️</span>
              <div>
                <p id="summary-text" class="summary-text">Esperando datos del clima...</p>
                <p class="summary-subtext">
                  Esta tarjeta resume de forma rápida el estado general de la ciudad buscada.
                </p>
              </div>
            </div>
          </article>
        </div>

		<div class="grid cards-3 extra-details-grid">
			<MetricCard
				title="Presión"
				valueId="pressure-value"
				value="-- mb"
				description="Presión atmosférica actual."
			/>

			<MetricCard
				title="Visibilidad"
				valueId="visibility-value"
				value="-- km"
				description="Distancia de visibilidad estimada."
			/>

			<MetricCard
				title="Hora local"
				valueId="localtime-value"
				value="--"
				description="Hora local de la ciudad consultada."
				largeLabel={true}
			/>
			</div>
		
      </div>
    </section>

    <section id="pronostico" class="section">
      <div class="container">
        <SectionTitle
          eyebrow="Sección 3"
          title="Pronóstico corto"
          text="Vista rápida de los próximos días. Después podemos mejorar todavía más esta sección."
        />

        <div id="forecast-list" class="forecast-grid">
          <article class="card forecast-item">
            <p class="forecast-day">--</p>
            <p class="forecast-emoji">🌤️</p>
            <p class="forecast-condition">Esperando datos...</p>
            <p class="forecast-range">--° / --°</p>
          </article>
        </div>
      </div>
    </section>
  </main>
</MainLayout>